# Copia este archivo a .env y ajusta los valores.

# Puerto del servicio único (API + WebSocket + estáticos)
PORT=3000

# Entorno: "production" exige JWT_SECRET y activa cookies "secure"
NODE_ENV=development

# Secreto para firmar los JWT. OBLIGATORIO en producción.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Validez del token de sesión
JWT_EXPIRES_IN=7d

# Ruta del archivo SQLite (opcional)
# DB_FILE=./apps/server/data/tictactoe.db
