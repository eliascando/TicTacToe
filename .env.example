# Copia este archivo a .env y ajusta los valores.

# Puerto del servicio único (API + WebSocket + estáticos)
PORT=3000

# Entorno: "production" exige JWT_SECRET y activa cookies "secure"
NODE_ENV=development

# Secreto para firmar los JWT. OBLIGATORIO en producción.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Validez del token de sesión
JWT_EXPIRES_IN=7d

# Ruta del archivo SQLite (opcional, modo desarrollo / instancia única)
# DB_FILE=./apps/server/data/tictactoe.db

# --- Escalabilidad horizontal (opcional) ---
# Si defines DATABASE_URL, se usa Postgres (base de datos COMPARTIDA entre instancias)
# en lugar de SQLite.
# DATABASE_URL=postgres://ttt:ttt@localhost:5432/ttt

# Si defines REDIS_URL, se activa el adaptador de Socket.IO y la cola/salas de
# matchmaking compartidas en Redis (necesario para correr varias instancias).
# REDIS_URL=redis://localhost:6379

# Identificador de instancia (útil para depurar en despliegues con varias réplicas)
# INSTANCE_ID=app1
